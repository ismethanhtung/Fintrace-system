# ─── Fintrace System — Environment Variables ─────────────────────────────────
# Copy file này thành .env và điền giá trị thật trước khi chạy.
# Không commit .env vào git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Redis ─────────────────────────────────────────────────────────────────────
# Địa chỉ Redis (dùng trong môi trường local, không cần đổi khi chạy Docker Compose)
REDIS_ADDR=localhost:6379

# Mật khẩu Redis — để trống nếu không cần auth (không khuyến nghị cho production)
REDIS_PASSWORD=

# Port Redis expose ra host (mặc định 6379)
REDIS_PORT=6379

# Redis database index (0-15)
REDIS_DB=0

# ── DNSE WebSocket ────────────────────────────────────────────────────────────
# Lấy từ DNSE OpenAPI portal: https://openapi.dnse.com.vn
DNSE_API_KEY=your_dnse_api_key_here
DNSE_API_SECRET=your_dnse_api_secret_here

# WebSocket URL của DNSE (thường không cần đổi)
DNSE_WS_URL=wss://ws-openapi.dnse.com.vn/v1/stream?encoding=json

# Board codes cần subscribe. G1=HOSE, G2=HNX, G3=UPCOM
DNSE_BOARDS=G1,G2,G3

# Market index cần subscribe realtime từ DNSE
DNSE_MARKET_INDEXES=VNINDEX,VN30,HNXIndex,HNX30,HNXUpcomIndex

# Symbol ticker cụ thể muốn nhận tick realtime (tối đa 300).
# Để trống = dùng cùng danh sách mặc định lớn như STOCK_SYMBOLS (xem code DefaultStockSymbols).
# Ví dụ thủ công: VCB,HPG,VNM,TCB,BID,CTG,VHM,GAS,SAB,MSN
DNSE_TICK_SYMBOLS=

# 1 = in tối đa 5 mẫu JSON đã auth nhưng worker chưa map được vào tick/index (debug parse).
DNSE_DEBUG=0

# ── Vietcap ───────────────────────────────────────────────────────────────────
# Nhóm cổ phiếu cần lấy snapshot priceboard
# Hỗ trợ: VN30, HOSE, HNX, UPCOM, và các custom group
VIETCAP_GROUPS=VN30,HOSE,HNX,UPCOM

# Khoảng thời gian (giây) giữa các lần lấy snapshot
VIETCAP_SNAPSHOT_INTERVAL_SEC=30

# Khoảng thời gian (giây) giữa các lần lấy market index
VIETCAP_MARKET_INDEX_INTERVAL_SEC=30

# ── KB Securities ─────────────────────────────────────────────────────────────
# Symbols cần lấy intraday chart (dùng cho mini-chart trên board)
KB_SYMBOLS=VNINDEX,VN30,HNX30,HNXINDEX,UPCOM

# Khoảng thời gian (giây) giữa các lần lấy intraday
KB_INTRADAY_INTERVAL_SEC=60
